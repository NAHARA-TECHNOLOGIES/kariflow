datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma" 
}


model Category {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique

  waitlists   Waitlist[]  @relation("WaitlistCategories")

  blogPosts   BlogPost[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}


model Waitlist {
  id            String      @id @default(uuid())

  fullName      String
  email         String      @unique
  businessType  String
  country       String
  state         String

  ipAddress     String?

  frequency     String      @default("weekly")

  categories    Category[]  @relation("WaitlistCategories")

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([email])
}


model Inquiry {
  id            String           @id @default(uuid())

  fullName      String
  email         String
  goal          String
  message       String           @db.Text

  status        String           @default("unread")

  replies       InquiryReply[]

  submittedAt   DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([status])
  @@index([email])
}

model InquiryReply {
  id            String      @id @default(uuid())

  inquiryId     String
  inquiry       Inquiry     @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  adminEmail    String
  message       String      @db.Text

  sentAt        DateTime    @default(now())

  @@index([inquiryId])
}



model BlogPost {
  id          String    @id @default(uuid())

  slug        String    @unique

  title       String

  excerpt     String    @db.Text

  content     String    @db.Text

  image       String?   @db.Text

  author      String

  readTime    String    @default("5 min read")

  published   Boolean   @default(false)

  featured    Boolean   @default(false)

  views        Int       @default(0)

  seoTitle     String?

  seoDescription String? @db.Text

  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id])

  tags        BlogTag[]

  createdAt   DateTime @default(now())

  updatedAt   DateTime @updatedAt

  @@index([slug])
  @@index([published])
  @@index([categoryId])
}

model BlogTag {
  id        String     @id @default(uuid())
  name      String     @unique
  slug      String     @unique

  blogs     BlogPost[]

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([slug])
}


model LegalDocument {
  slug         String   @id
  title        String
  content      String   @db.Text
  lastRevised  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}





model CookieConsentLog {
  id            String      @id @default(uuid())

  anonymousId   String

  necessary     Boolean     @default(true)

  analytics     Boolean

  marketing     Boolean

  userAgent     String       @db.Text

  country       String?

  city          String?

  timestamp     DateTime     @default(now())

  @@index([anonymousId])
}


model BrandingSettings {
  id            String      @id @default("global")

  logoMode      String      @default("svg")

  customUrl     String?     @db.Text

  updatedAt     DateTime    @updatedAt
}



model AdminUser {
  id            String   @id @default(cuid())

  firstName     String

  lastName      String

  email         String   @unique

  password      String

  role          AdminRole @default(ADMIN)

  avatar        String?

  active        Boolean  @default(true)

  lastLogin     DateTime?

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

model EmailTemplate {
  id            String   @id @default("global")
  headerColor   String   @default("#111827")
  footerColor   String   @default("#111827")
  accentColor   String   @default("#2563eb")
  footerText    String   @db.Text
  updatedAt     DateTime @updatedAt
}
model NewsletterSubscriber {
  id              String   @id @default(uuid())
  email           String   @unique
  firstName       String?
  active          Boolean  @default(true)

  frequency       String   @default("weekly")

  lastSentAt      DateTime?
  nextScheduledAt DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

